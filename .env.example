# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Resend (email)
RESEND_API_KEY=re_...

# Google Maps
# Client-side key: restrict to HTTP Referrers (your domain) + Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# Server-side key: restrict to IP addresses + Places API + Geocoding API
GOOGLE_MAPS_SERVER_KEY=AIza...

# Site URL
NEXT_PUBLIC_SITE_URL=https://analogfood.co
